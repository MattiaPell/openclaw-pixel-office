# OpenClaw Pixel Office - Environment Variables

# URL of the internal API server (e.g. http://localhost:3004)
# This server maps OpenClaw session data to the dashboard.
VITE_OPENCLAW_API_URL=http://localhost:3004

# URL of the OpenClaw Gateway (e.g. http://localhost:18789)
# Used for direct agent discovery and interaction.
VITE_OPENCLAW_GATEWAY_URL=http://localhost:18789

# Bearer token for OpenClaw Gateway authentication (optional)
VITE_OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Default agents configuration in JSON format (optional fallback)
# Example: '[{"id":"agent-1","name":"Alpha","status":"idle"}]'
VITE_AGENTS=
